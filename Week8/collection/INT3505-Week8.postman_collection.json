{
  "info": {
    "_postman_id": "week8-int3505-2026",
    "name": "INT3505 Week8 - API Test Suite",
    "description": "Postman test suite for INT3505 Week 8. Tests 5 endpoints from two Flask apps: Book CRUD (port 5000) and JWT Auth (port 5001).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "book-api-url", "value": "http://localhost:5000" },
    { "key": "jwt-api-url",  "value": "http://localhost:5001" },
    { "key": "accessToken",  "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "bookId",       "value": "" }
  ],
  "item": [
    {
      "name": "Book API",
      "item": [
        {
          "name": "1. Create Book",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Body has numeric id', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.id).to.be.a('number');",
                  "    pm.collectionVariables.set('bookId', json.id);",
                  "});",
                  "pm.test('Title matches', function () {",
                  "    pm.expect(pm.response.json().title).to.eql('Test-Driven Book');",
                  "});",
                  "pm.test('Author matches', function () {",
                  "    pm.expect(pm.response.json().author).to.eql('Postman Author');",
                  "});",
                  "pm.test('Content-Type is application/json', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Test-Driven Book\",\n    \"author\": \"Postman Author\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{book-api-url}}/books",
              "host": ["{{book-api-url}}"],
              "path": ["books"]
            }
          }
        },
        {
          "name": "2. Get Book by ID",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var bookId = pm.collectionVariables.get('bookId');",
                  "console.log('Debug: bookId =', bookId);",
                  "if (bookId) {",
                  "    pm.request.url = '{{book-api-url}}/books/' + bookId;",
                  "} else {",
                  "    console.error('No bookId found, using default');",
                  "    pm.request.url = '{{book-api-url}}/books/1';",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Book id matches collection variable', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.id).to.eql(pm.collectionVariables.get('bookId'));",
                  "});",
                  "pm.test('Title matches created book', function () {",
                  "    pm.expect(pm.response.json().title).to.eql('Test-Driven Book');",
                  "});",
                  "pm.test('Author matches created book', function () {",
                  "    pm.expect(pm.response.json().author).to.eql('Postman Author');",
                  "});",
                  "pm.test('Content-Type is application/json', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{book-api-url}}/books/{{bookId}}",
              "host": ["{{book-api-url}}"],
              "path": ["books", "{{bookId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "JWT Auth API",
      "item": [
        {
          "name": "3. Login - Get Tokens",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('accessToken exists and is non-empty', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.accessToken).to.be.a('string');",
                  "    pm.expect(json.accessToken).to.have.length.above(10);",
                  "    pm.collectionVariables.set('accessToken', json.accessToken);",
                  "});",
                  "pm.test('refreshToken exists and is non-empty', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.refreshToken).to.be.a('string');",
                  "    pm.expect(json.refreshToken).to.have.length.above(10);",
                  "    pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "});",
                  "pm.test('accessToken is valid JWT format (3 parts)', function () {",
                  "    var parts = pm.response.json().accessToken.split('.');",
                  "    pm.expect(parts.length).to.eql(3);",
                  "});",
                  "pm.test('refreshToken is valid JWT format (3 parts)', function () {",
                  "    var parts = pm.response.json().refreshToken.split('.');",
                  "    pm.expect(parts.length).to.eql(3);",
                  "});",
                  "pm.test('Content-Type is application/json', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"admin\",\n    \"password\": \"password\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{jwt-api-url}}/api/login",
              "host": ["{{jwt-api-url}}"],
              "path": ["api", "login"]
            }
          }
        },
        {
          "name": "4. Access Protected Route",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var token = pm.collectionVariables.get('accessToken');",
                  "console.log('Debug: accessToken =', token);",
                  "if (token && token.startsWith('ey')) {",
                  "    pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + token });",
                  "} else {",
                  "    console.error('No valid accessToken found');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Message contains username', function () {",
                  "    pm.expect(pm.response.json().message).to.include('admin');",
                  "});",
                  "pm.test('User object exists with username=admin', function () {",
                  "    var user = pm.response.json().user;",
                  "    pm.expect(user).to.be.an('object');",
                  "    pm.expect(user.username).to.eql('admin');",
                  "});",
                  "pm.test('User role is admin', function () {",
                  "    pm.expect(pm.response.json().user.role).to.eql('admin');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{jwt-api-url}}/api/protected",
              "host": ["{{jwt-api-url}}"],
              "path": ["api", "protected"]
            }
          }
        },
        {
          "name": "5. Access Admin Route",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var token = pm.collectionVariables.get('accessToken');",
                  "console.log('Debug: accessToken =', token);",
                  "if (token && token.startsWith('ey')) {",
                  "    pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + token });",
                  "} else {",
                  "    console.error('No valid accessToken found');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 (admin access granted)', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Admin message contains expected text', function () {",
                  "    pm.expect(pm.response.json().message).to.include('Admin');",
                  "});",
                  "pm.test('Message confirms RBAC success', function () {",
                  "    pm.expect(pm.response.json().message).to.include('mật');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{jwt-api-url}}/api/admin",
              "host": ["{{jwt-api-url}}"],
              "path": ["api", "admin"]
            }
          }
        }
      ]
    }
  ]
}